{
  "info": {
    "_postman_id": "8fb8efb4-8e60-4f86-9f80-techmarketia",
    "name": "TechMarket Oaxaca - API de IA",
    "description": "Pruebas de la API externa Google Gemini y de los endpoints de IA integrados en Ruby on Rails.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://10.65.57.201:3000"
    },
    {
      "key": "gemini_api_key",
      "value": ""
    },
    {
      "key": "gemini_model",
      "value": "gemini-3.5-flash"
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "usuario_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Proveedor externo Gemini",
      "item": [
        {
          "name": "Probar Gemini directamente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-goog-api-key",
                "value": "{{gemini_api_key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{gemini_model}}\",\n  \"input\": \"Responde en español y en tres líneas: ¿qué es una API REST?\",\n  \"store\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://generativelanguage.googleapis.com/v1/interactions",
              "protocol": "https",
              "host": [
                "generativelanguage",
                "googleapis",
                "com"
              ],
              "path": [
                "v1",
                "interactions"
              ]
            },
            "description": "Demuestra que la clave y el modelo de Google Gemini funcionan antes de probar el backend Rails."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gemini respondió correctamente', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('La respuesta contiene salida del modelo', function () {",
                  "  pm.expect(json.steps).to.be.an('array').that.is.not.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Autenticación",
      "item": [
        {
          "name": "Login administrador",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@techmarket.com\",\n  \"password\": \"12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login administrador correcto', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('admin_token', json.token);",
                  "pm.expect(json.usuario.rol).to.eql('administrador');"
                ]
              }
            }
          ]
        },
        {
          "name": "Login usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"usuario@techmarket.com\",\n  \"password\": \"12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login usuario correcto', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('usuario_token', json.token);",
                  "pm.expect(json.usuario.rol).to.eql('usuario');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - API de IA en Rails",
      "item": [
        {
          "name": "Estado de la integración - administrador",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/ia/estado"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Solo el administrador consulta el estado', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.expect(json.proveedor).to.eql('Google Gemini');",
                  "pm.expect(json.configurada).to.eql(true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Chat del catálogo - usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{usuario_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pregunta\": \"¿Qué productos con promoción tienen disponibles y cuál es el más económico?\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/ia/chat"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('El chatbot responde usando JWT', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.expect(json.funcion).to.eql('chatbot_catalogo');",
                  "pm.expect(json.respuesta).to.be.a('string').that.is.not.empty;",
                  "pm.expect(json.consulta_id).to.exist;"
                ]
              }
            }
          ]
        },
        {
          "name": "Recomendaciones personalizadas - usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{usuario_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"presupuesto\": 20000,\n  \"uso\": \"programación, clases virtuales y tareas universitarias\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/ia/recomendaciones"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('La recomendación fue generada', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.expect(json.funcion).to.eql('recomendaciones_personalizadas');",
                  "pm.expect(json.productos_recomendados).to.be.an('array').that.is.not.empty;",
                  "pm.expect(json.respuesta).to.be.a('string').that.is.not.empty;"
                ]
              }
            }
          ]
        },
        {
          "name": "Historial propio de IA - usuario",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{usuario_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/consultas_ia"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('El usuario consulta su historial', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.expect(json.consultas).to.be.an('array');"
                ]
              }
            }
          ]
        },
        {
          "name": "Historial completo de IA - administrador",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/consultas_ia"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('El administrador consulta todo el historial', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Pruebas de seguridad",
      "item": [
        {
          "name": "Chat sin JWT - debe bloquear",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pregunta\": \"¿Qué productos existen?\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/ia/chat"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('La API bloquea solicitudes sin token', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Estado con token de usuario - debe bloquear",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{usuario_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/ia/estado"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Solo administrador puede revisar configuración', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
