# Copia este archivo como .env solamente si utilizas una herramienta que lo cargue.
# Rails no carga .env automáticamente sin una gema adicional.
# En Windows y Ubuntu se recomienda definir estas variables en el sistema o terminal.

GEMINI_API_KEY=COLOCA_AQUI_TU_CLAVE_PRIVADA
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1/interactions

# Opcional: usa una clave larga y privada para firmar JWT.
JWT_SECRET=CAMBIA_ESTA_CLAVE_EN_CADA_ENTORNO
